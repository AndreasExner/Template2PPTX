{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CLevel_Deck_Data",
  "description": "Geschäftsdatenmodell (C-Level 5-Slide Schema) zur späteren Transformation auf konkrete PPTX-Placeholders/Charts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "basis",
    "executiveSummary",
    "value",
    "reliabilitySafety",
    "technology",
    "tco"
  ],
  "properties": {
    "basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "market",
        "modelYear",
        "segment"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Deck-Titel (Slide 1)."
        },
        "subtitle": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "description": "z.B. 26.02.2026"
        },
        "market": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "trimLevel": {
          "type": "string"
        },
        "segment": {
          "type": "string"
        },
        "priceRange": {
          "type": "string"
        },
        "itemsSold": {
          "type": "string"
        },
        "marketShareInSegment": {
          "type": "string"
        },
        "disclaimerDataSource": {
          "type": "string"
        },
        "heroImage": {
          "$ref": "#/definitions/imageInput"
        }
      }
    },
    "executiveSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overallScore",
        "segmentRanking",
        "recommendation",
        "strengths",
        "weaknesses"
      ],
      "properties": {
        "overallScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "rangeKm": {
          "type": "string"
        },
        "costPerKm": {
          "type": "string"
        },
        "segmentRanking": {
          "type": "string",
          "description": "z.B. 2/10"
        },
        "recommendation": {
          "type": "string",
          "enum": [
            "Ja",
            "Mit Einschränkungen",
            "Nein"
          ]
        },
        "recommendationRationale": {
          "type": "string"
        },
        "strengths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string"
          }
        },
        "weaknesses": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string"
          }
        },
        "dataFootnote": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primarySourcesCount": {
              "type": "integer",
              "minimum": 0
            },
            "lastUpdated": {
              "type": "string"
            },
            "gaps": {
              "type": "string"
            }
          }
        }
      }
    },
    "value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cLevelTakeaway",
        "competitors",
        "chart"
      ],
      "properties": {
        "cLevelTakeaway": {
          "type": "string"
        },
        "competitors": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "value"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string",
                "description": "Kurzbewertung/Index/Preis."
              }
            }
          }
        },
        "chart": {
          "$ref": "#/definitions/valueChart"
        }
      }
    },
    "reliabilitySafety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reliabilityScore",
        "reliabilityRisk",
        "safetyScore",
        "safetyPositioning",
        "reliabilityBullets",
        "safetyBullets"
      ],
      "properties": {
        "reliabilityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "reliabilityRisk": {
          "type": "string",
          "enum": [
            "niedrig",
            "mittel",
            "hoch"
          ]
        },
        "safetyScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "safetyPositioning": {
          "type": "string"
        },
        "reliabilityBullets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string"
          }
        },
        "safetyBullets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "technology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "differentiationPotential",
        "chart"
      ],
      "properties": {
        "differentiationPotential": {
          "type": "string",
          "enum": [
            "Cutting-Edge",
            "Advanced",
            "Competitive",
            "Basic"
          ]
        },
        "chart": {
          "$ref": "#/definitions/techChart"
        }
      }
    },
    "tco": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tcoIndex",
        "tco5y",
        "costPerMonth",
        "depreciation",
        "kpi",
        "chart"
      ],
      "properties": {
        "tcoIndex": {
          "type": "string"
        },
        "tco5y": {
          "type": "string"
        },
        "costPerMonth": {
          "type": "string"
        },
        "depreciation": {
          "type": "string"
        },
        "kpi": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tcoIndex",
            "tco",
            "costPerKm"
          ],
          "properties": {
            "tcoIndex": {
              "type": "string"
            },
            "tco": {
              "type": "string"
            },
            "costPerKm": {
              "type": "string"
            }
          }
        },
        "chart": {
          "$ref": "#/definitions/tcoChart"
        }
      }
    }
  },
  "definitions": {
    "imageInput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fileName": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "contentType": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "fileName"
          ]
        },
        {
          "required": [
            "url"
          ]
        }
      ]
    },
    "valueChart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "categories",
        "series"
      ],
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 4,
          "maxItems": 4,
          "default": [
            "Price Index",
            "Equipment Score",
            "Value‑Rating",
            "Value‑for‑Money Index"
          ]
        },
        "series": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/namedSeries"
          }
        }
      }
    },
    "techChart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "categories",
        "series"
      ],
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 4,
          "maxItems": 4,
          "default": [
            "Digital Keys",
            "Comfort",
            "Connectivity",
            "Infotainment"
          ]
        },
        "series": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/namedSeries"
          }
        }
      }
    },
    "tcoChart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "categories",
        "series"
      ],
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 5,
          "maxItems": 5,
          "default": [
            "Depreciation",
            "Energy/Fuel",
            "Insurance",
            "Maintenance",
            "Tax"
          ]
        },
        "series": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/namedSeries"
          }
        }
      }
    },
    "namedSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "values"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 1
        }
      }
    }
  }
}