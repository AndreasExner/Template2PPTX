  "definitions": {
    "chartInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shapeName",
        "categories",
        "series"
      ],
      "properties": {
        "shapeName": {
          "type": "string",
          "minLength": 1,
          "description": "Name der Chart-Shape (Selection Pane)."
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "series": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "values"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "values": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "imageInput": {
      "type": "object",
      "additionalProperties": false,
      "description": "Beschreibt, woher das Bild kommt. Bei ReplaceImages musst du die Datei tatsächlich als multipart-Dateifeld senden; dieses Objekt dient als Steuerdaten für deinen Flow/Agent.",
      "properties": {
        "fileName": {
          "type": "string",
          "description": "Dateiname/Attachment-Name, der als multipart-Dateifeld hochgeladen wird."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Optional: URL, von der dein Flow das Bild zuerst herunterlädt."
        },
        "contentType": {
          "type": "string",
          "description": "Optional: MIME-Type (image/png, image/jpeg, …)."
        },
        "altText": {
          "type": "string",
          "description": "Optional: Alt-Text/Caption (wird nicht automatisch ins PPTX geschrieben)."
        }
      },
      "anyOf": [
        {
          "required": [
            "fileName"
          ]
        },
        {
          "required": [
            "url"
          ]
        }
      ]
    }
