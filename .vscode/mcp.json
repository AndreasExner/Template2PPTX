{
  "servers": {
    "template2pptx-local": {
      "type": "http",
      "url": "http://localhost:7071/runtime/webhooks/mcp"
    },
    "template2pptx-remote": {
      "type": "http",
      "url": "https://${input:functionapp-domain}/runtime/webhooks/mcp",
      "headers": {
        "x-functions-key": "${input:functions-key}"
      }
    }
  },
  "inputs": [
    {
      "type": "promptString",
      "id": "functionapp-domain",
      "description": "The domain of the function app (e.g. ttemplate2pptx.azurewebsites.net)",
      "password": false
    },
    {
      "type": "promptString",
      "id": "functions-key",
      "description": "Azure Functions system key for MCP webhook",
      "password": true
    }
  ]
}
